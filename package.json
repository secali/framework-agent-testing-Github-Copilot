{
  "name": "copilot-agent-testing",
  "version": "1.0.0",
  "description": "Test automation framework for GitHub Copilot agents",
  "main": "dist/index.js",
  "bin": {
    "cat": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "test": "tsx src/index.ts run",
    "test:suite": "tsx src/index.ts run --suite",
    "lint": "eslint src/",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "yaml": "^2.6.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "glob": "^11.0.2",
    "ajv": "^8.17.1",
    "openai": "^4.85.4"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsx": "^4.19.3",
    "@types/node": "^22.13.5",
    "eslint": "^9.21.0"
  },
  "engines": {
    "node": ">=20"
  }
}
